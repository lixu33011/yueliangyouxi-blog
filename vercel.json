{
  "version": 2,
  "routes": [
    {
      "src": "/backgrounds/(.*)",
      "dest": "/backgrounds/$1",
      "handle": "filesystem"
    },
    {
      "src": "/templates/(.*)",
      "dest": "/templates/$1",
      "handle": "filesystem"
    },
    {
      "src": "/data/(.*)",
      "dest": "/data/$1",
      "handle": "filesystem"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "/uploads/$1",
      "handle": "filesystem"
    },
    {
      "src": "/(.*\\.php$|^/admin$)",
      "dest": "/api/index.js",
      "handle": "rewrite"
    },
    {
      "src": "/",
      "dest": "/api/index.js",
      "handle": "rewrite",
      "continue": false
    }
  ],
  "env": {
    "PHP_VERSION": "7.4",
    "NODE_ENV": "production"
  }
}
